{
  "name": "Subscriber",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the subscriber"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "The email address of the subscriber"
    }
  },
  "required": [
    "name",
    "email"
  ],
  "rls": {
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "write": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}