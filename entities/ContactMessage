{
  "name": "ContactMessage",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the person contacting"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "The email address of the person contacting"
    },
    "subject": {
      "type": "string",
      "enum": [
        "Privacy",
        "Releases",
        "General Info",
        "Sync Placements"
      ],
      "description": "The subject category of the inquiry"
    },
    "message": {
      "type": "string",
      "description": "The message content"
    }
  },
  "required": [
    "name",
    "email",
    "subject",
    "message"
  ],
  "rls": {
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "write": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}